TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TAVILY_API_KEY=your_tavily_api_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=research-agent-docs
BEDROCK_AGENT_ID=will_be_set_after_deploy
BEDROCK_AGENT_ALIAS_ID=will_be_set_after_deploy
KNOWLEDGE_BASE_ID=will_be_set_after_deploy
WEBHOOK_URL=will_be_set_after_deploy

# Provider switch: "aws" or "azure"
PROVIDER=aws

# Azure OpenAI (required when PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
